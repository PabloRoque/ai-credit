{
  "name": "ai-credit",
  "version": "1.0.3",
  "description": "CLI tool to track and analyze AI coding assistants' contributions in your codebase",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "ai-credit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc && node dist/cli.js",
    "pub": "npm run build && npm publish",
